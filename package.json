{
  "name": "@GKz/image-compression",
  "version": "0.10.15",
  "description": "Framework-agnostic image compression for the browser. Pure web APIs (WebCodecs, OffscreenCanvas, Comlink Worker). Works with any frontend framework (Angular, React, Vue, Svelte) or vanilla JS.",
  "repository": {
    "type": "git",
    "url": "git@gitlab.com:guidekungz/image-compression.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:watch": "node scripts/build.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.json",
    "size": "size-limit",
    "prepublishOnly": "npm run lint && npm test && npm run build && npm run size && npm run docs",
    "docs": "typedoc"
  },
  "keywords": [
    "image",
    "compression",
    "webcodecs",
    "offscreen-canvas",
    "worker",
    "comlink",
    "browser",
    "framework-agnostic",
    "heic",
    "exif"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "comlink": "^4.4.2"
  },
  "peerDependencies": {
    "heic2any": "^0.0.4"
  },
  "peerDependenciesMeta": {
    "heic2any": {
      "optional": true
    }
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@size-limit/preset-app": "^12.1.0",
    "@types/node": "^20.10.0",
    "happy-dom": "^15.0.0",
    "size-limit": "^12.1.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}